{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mush_stream",
  "version": "0.1.0",
  "identifier": "com.github.drewchase.mushstream",
  "build": {
    "devUrl": "http://localhost:1420",

    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",

    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mush Stream",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 450,
        "decorations": false

      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5MkQyQkYxMkVBNTIyMTAKUldRUUlxVXU4U3N0eVQralVucmxEU3lBUjNpSStJKzB6UW1YRWh6ejE4UWNiRm9ySlEvSzdPakwK",
      "endpoints": [
        "https://github.com/Drew-Chase/mush-stream/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../ViGEmBus_1.18.367_x64_x86.exe": "ViGEmBus_1.18.367_x64_x86.exe"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./installer-hooks.nsh",
        "installMode": "perMachine"
      }
    }
  }
}
