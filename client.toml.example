# mush-stream client config
#
# Copy to client.toml and edit. The client binary loads ./client.toml by
# default; pass a path as the first CLI arg to override.

[network]
# Host's UDP address — the only thing this client needs to know about
# the network. The client connects its UDP socket here; the host learns
# the client's address from that first packet (UDP hole-punch) and
# starts sending video back.
host = "127.0.0.1:9002"

[display]
# Pixel buffer dimensions. Match the host's capture rect to avoid scaling.
width = 2560
height = 1440
title = "mush-stream"
fullscreen = false

[decode]
# Try h264_cuvid first; if it fails to initialize, fall back to the
# bundled software h264 decoder. Set false if you're sure you don't
# have an NVIDIA GPU (skips the failed-open warning).
prefer_hardware = true
