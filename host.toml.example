# mush-stream host config
#
# Copy this file to `host.toml` and edit. The host binary loads `./host.toml`
# by default; pass a path as the first CLI arg to override.

[capture]
# Index of the DXGI output to capture. 0 = primary monitor.
output_index = 0
# Top-left corner of the capture region, in pixels, relative to the chosen output.
x = 2560
y = 0
# Size of the capture region, in pixels.
width = 2560
height = 1440

[network]
# UDP port the host listens on. Clients put this in their `host` config.
# The host learns each client's address from the first packet it
# receives, so no peer/address goes here — the local IP is implicit.
listen_port = 9002
# When true, ask the local router to forward `listen_port` via UPnP at
# startup so a client across NAT can reach this host without manual
# port forwarding.
enable_upnp = false

[encode]
# H.264 NVENC target bitrate in kbps. 9 Mbps is the default — paired
# with the encoder's preset=p4 + spatial-aq + multipass=qres tuning,
# this gives clean output at 1440p60 over a typical home upload link.
# Bump higher if you have headroom and want more detail; the encoder
# is configured CBR so it'll fill whatever you give it.
bitrate_kbps = 9000
# Capture/encode framerate. Match (or be a divisor of) the host's
# display refresh rate. DXGI delivers frames at the display's refresh;
# setting fps higher than that won't produce more real frames.
fps = 60
